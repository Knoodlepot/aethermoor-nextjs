{
  "name": "aethermoor-nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "verify:runtime": "tsx __tests__/manual/verifyRuntime.ts",
    "verify:mock-state": "tsx __tests__/manual/mockClaudeStateHarness.ts",
    "verify:narrator": "node __tests__/manual/narratorTurnTest.cjs",
    "verify:narrator:prod": "powershell -NoProfile -Command \"$env:NEXT_PUBLIC_URL='https://aethermoor-nextjs.vercel.app'; node __tests__/manual/narratorTurnTest.cjs\"",
    "verify:all": "npm run verify:runtime && npm run verify:mock-state && npm run verify:narrator",
    "test": "vitest run",
    "verify:unit": "vitest run",
    "e2e": "playwright test",
    "verify:e2e": "playwright test"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "jsonwebtoken": "^9.0.3",
    "next": "16.1.6",
    "pg": "^8.20.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "redis": "^5.11.0",
    "stripe": "^20.4.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.37",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/redis": "^4.0.10",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "playwright": "^1.58.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}

# Aethermoor Next.js Environment Variables
# Copy this to .env.local and fill in your values.

# --------------------------------------------------
# Minimum for auth + saves + local runtime verifier
# --------------------------------------------------
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
JWT_SECRET=replace-with-32-plus-character-secret
SESSION_SECRET=replace-with-32-plus-character-secret
NEXT_PUBLIC_URL=http://localhost:3000

# --------------------------------------------------
# Required for live narrator calls
# --------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# Optional model routing tweak
HAIKU_PCT=90

# --------------------------------------------------
# Required for token purchases / Stripe webhook flow
# --------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --------------------------------------------------
# Required for email verification / password reset
# --------------------------------------------------
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@aethermoor.com

# --------------------------------------------------
# Required for OAuth flows
# --------------------------------------------------
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=http://localhost:3000/auth

DISCORD_CLIENT_ID=...
DISCORD_CLIENT_SECRET=...
DISCORD_REDIRECT_URI=http://localhost:3000/auth

# --------------------------------------------------
# Optional integrations
# --------------------------------------------------
REDIS_URL=redis://localhost:6379

# Legacy/support-side Discord settings if still used elsewhere
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_WEBHOOK_URL=

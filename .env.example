# Aethermoor — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Railway, Supabase, Neon, etc.)
DATABASE_URL=postgresql://user:password@host:5432/aethermoor

# ── Authentication ────────────────────────────────────────────────────────────
# Secret used to sign JWTs. Must be long and random.
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars

# Secret used for admin API endpoints (x-admin-secret header).
SESSION_SECRET=change-this-to-another-long-random-string

# ── Anthropic AI ──────────────────────────────────────────────────────────────
# API key for Claude (narrator AI).
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Stripe (payments) ─────────────────────────────────────────────────────────
# Secret key from your Stripe dashboard.
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret from Stripe → Developers → Webhooks.
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (Resend) ────────────────────────────────────────────────────────────
# API key from resend.com for sending verification and password-reset emails.
RESEND_API_KEY=re_...

# From address for outbound emails (must be a verified sender in Resend).
EMAIL_FROM=noreply@yourdomain.com

# ── Redis (optional) ──────────────────────────────────────────────────────────
# If not set, the app falls back to in-memory rate limiting and token blocking.
# Required for rate limiting and JWT revocation to work across serverless instances.
REDIS_URL=redis://localhost:6379

# ── Beta Access Gate (optional) ───────────────────────────────────────────
# SHA-256 hash of the plaintext beta access code.
# Generate a code+hash pair with:
#   node -e "const c=require('crypto');const code=c.randomBytes(16).toString('hex');console.log('CODE:',code);console.log('HASH:',c.createHash('sha256').update(code).digest('hex'));"
# Give CODE to testers. Store only HASH here. Never commit CODE.
# Leave unset to disable the gate (open access).
BETA_CODE_HASH=

# ── App ───────────────────────────────────────────────────────────────────────
# Public base URL used for email links (verification, password reset).
NEXT_PUBLIC_URL=http://localhost:3000

# ── Analytics (Posthog) ───────────────────────────────────────────────────────
# Get from app.posthog.com → Project Settings → Project API Key
# Leave blank to disable analytics.
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ── Error tracking (Sentry) ───────────────────────────────────────────────────
# Run: npx @sentry/wizard@latest -i nextjs  (sets up sentry.*.config.ts automatically)
# Get DSN from sentry.io → Project Settings → Client Keys
# Leave blank to disable error tracking.
NEXT_PUBLIC_SENTRY_DSN=https://...@...ingest.sentry.io/...
